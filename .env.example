# ───────────────────────────────────────────────────────────
# Boldfy site — env vars template
# Copia pra .env.local e preenche os valores.
# As que começam com NEXT_PUBLIC_ ficam expostas no bundle client.
# ───────────────────────────────────────────────────────────

# Notion (blog, beta, materiais)
NOTION_API_KEY=
NOTION_BETA_DB_ID=
NOTION_BLOG_DATABASE_ID=

# ActiveCampaign (email automation + CRM)
ACTIVECAMPAIGN_API_URL=
ACTIVECAMPAIGN_API_KEY=

# ───────────────────────────────────────────────────────────
# Analytics & tracking (client-side)
# ───────────────────────────────────────────────────────────

# Google Tag Manager — orquestra GA4 e LinkedIn Insight
# Formato: GTM-XXXXXXX
NEXT_PUBLIC_GTM_ID=

# Google Analytics 4 — fallback direto (inativo se GTM_ID presente)
# Formato: G-XXXXXXXXXX
NEXT_PUBLIC_GA4_ID=

# LinkedIn Insight Tag — fallback direto (inativo se GTM_ID presente)
# Formato: número de 6-7 dígitos (Partner ID, não Account ID)
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=

# ActiveCampaign Site Tracking (VGO) — tracking comportamental
# Formato: número de 8 dígitos (Account ID do AC)
NEXT_PUBLIC_AC_ACCOUNT_ID=
